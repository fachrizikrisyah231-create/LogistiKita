{
  "name": "logistikita-mock-server",
  "version": "1.0.0",
  "description": "Mock server: SmartBank, API Gateway, dan Trigger untuk LogistiKita",
  "scripts": {
    "start": "concurrently \"node smartbank.mock.js\" \"node gateway.mock.js\" \"node trigger.mock.js\"",
    "start:smartbank": "node smartbank.mock.js",
    "start:gateway": "node gateway.mock.js",
    "start:trigger": "node trigger.mock.js",
